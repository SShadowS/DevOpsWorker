{
  "name": "devops-pipeline",
  "version": "0.1.0",
  "module": "src/cli/index.ts",
  "type": "module",
  "private": true,
  "bin": {
    "pipeline": "./src/cli/index.ts"
  },
  "scripts": {
    "pipeline": "bun run src/cli/index.ts",
    "analyze-docs": "bun run scripts/analyze-doc-styles.ts",
    "test": "bun test --preload ./tests/setup.ts tests/sdk tests/pipeline tests/cli tests/config tests/overlay tests/webhook-server tests/formatters tests/dashboard tests/agents",
    "test:unit": "bun test --preload ./tests/setup.ts tests/sdk tests/pipeline tests/cli tests/config tests/overlay tests/webhook-server tests/formatters tests/dashboard",
    "test:integration": "bun test --preload ./tests/setup.ts tests/integration",
    "test:all": "bun test --preload ./tests/setup.ts",
    "typecheck": "tsc --noEmit",
    "dashboard": "bun run src/cli/index.ts dashboard",
    "dashboard:build": "bun src/dashboard/build.ts",
    "dashboard:dev": "bun --watch src/dashboard/build.ts"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "0.3.162",
    "@preact/signals": "^2.9.1",
    "@sshadows/tree-sitter-al": "^3.0.1",
    "postgres": "^3.4.9",
    "preact": "^10.29.2",
    "web-tree-sitter": "^0.26.9",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@types/bun": "^1.3.14",
    "typescript": "^6.0.3"
  }
}
